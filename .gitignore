# ---- STM32CubeIDE build artifacts ----
# Build output folders are regenerated by the IDE on import + build.
Debug/
Release/

# Per-user binary / object output
*.o
*.d
*.su
*.elf
*.bin
*.hex
*.map
*.list
*.cyclo

# CubeIDE auto-generates the makefile inside Debug/ on every build
**/Debug/makefile
**/Debug/sources.mk
**/Debug/objects.mk
**/Debug/objects.list

# ---- Eclipse / CubeIDE workspace cruft ----
.metadata/
RemoteSystemsTempFiles/
.recommenders/
*.launch.bak
local.properties

# Keep these so others can import the project:
#   .project, .cproject, .mxproject, .settings/, *.ioc,
#   *.ld (linker scripts), Core/, Drivers/, Middlewares/, USB_HOST/

# ---- OS / editor noise ----
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/
